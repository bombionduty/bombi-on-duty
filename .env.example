# =====================================================================
# Berry Bomb Daily Ops — Environment Variables
# =====================================================================
# Copy this file to ".env" and fill in real values.
#   cp .env.example .env
# NEVER commit your real .env file. It is already in .gitignore.
# Every value below is explained in the README "Setup" section.
# =====================================================================

# ---- Telegram ----
# From @BotFather after /newbot
TELEGRAM_BOT_TOKEN=123456789:PUT-YOUR-REAL-BOT-TOKEN-HERE
# Your bot's username WITHOUT the @ (e.g. BerryBombOpsBot)
BOT_USERNAME=BerryBombOpsBot
# The Mini App short name you set in @BotFather (/newapp). e.g. ops
MINIAPP_SHORT_NAME=ops

# Your own numeric Telegram User ID (NOT your username).
# Get it from @userinfobot. This person is the Admin.
ADMIN_TELEGRAM_USER_ID=000000000

# The numeric chat ID of the Staff Daily Ops group (starts with -100...).
# The README explains how to find this.
STAFF_GROUP_CHAT_ID=-1000000000000

# ---- Google ----
# The ID in the middle of your Google Sheet URL:
# https://docs.google.com/spreadsheets/d/THIS_PART/edit
GOOGLE_SHEET_ID=PUT-YOUR-SHEET-ID-HERE
# The folder ID from your Google Drive evidence folder URL:
# https://drive.google.com/drive/folders/THIS_PART
GOOGLE_DRIVE_EVIDENCE_FOLDER_ID=PUT-YOUR-DRIVE-FOLDER-ID-HERE
# Path to the downloaded service-account JSON key file.
GOOGLE_SERVICE_ACCOUNT_FILE=service_account.json

# ---- App ----
# Public HTTPS base URL where this app is deployed (no trailing slash).
# Telegram requires HTTPS for webhooks and Mini Apps.
# Example: https://berry-bomb-ops.onrender.com
APP_BASE_URL=https://your-app.onrender.com

# Long random string used to sign/verify internal tokens.
# Generate one with:  python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-string

# Timezone — keep this for Berry Bomb.
TIMEZONE=Asia/Manila

# ---- Modes ----
# TEST_MODE=true uses test labels and immediate test triggers.
# Set to false for real production operation.
TEST_MODE=true
# Human label shown in messages: e.g. development / production
ENVIRONMENT_NAME=development

# Webhook vs polling. In production use "webhook". For quick local
# testing without a public URL you can use "polling".
TELEGRAM_MODE=webhook

# Port the web server listens on (most hosts set this automatically).
PORT=8000

# ---- Daily Owner Brief (Zite inventory integration) — OPTIONAL ----
# The bot triggers this external report every morning. Leave blank to disable.
# Zite's POST endpoint that generates the report:
ZITE_OWNER_BRIEF_URL=
# The secret API token Zite expects in the request body:
ZITE_OWNER_BRIEF_TOKEN=
# Comma-separated email recipients for the report:
OWNER_EMAILS=leshamgmt@gmail.com
# Telegram chat to send failures to now (and the report itself, in the future).
# Defaults to the admin's DM if left blank.
OWNER_TELEGRAM_CHAT_ID=
# Local time (Asia/Manila) to trigger it each day:
OWNER_BRIEF_TIME=09:00
